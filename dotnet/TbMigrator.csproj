<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>tbmigrator</AssemblyName>
    <RootNamespace>TbMigrator</RootNamespace>
    <Optimize>true</Optimize>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Npgsql"                  Version="10.*" />
    <PackageReference Include="CassandraCSharpDriver"   Version="3.*" />
    <PackageReference Include="YamlDotNet"              Version="18.*" />
    <PackageReference Include="Spectre.Console"         Version="0.*" />
  </ItemGroup>
</Project>
